# Copy this file to `.env` and fill in real values.
#
# SECURITY: never commit the real `.env` file.
# - `.gitignore` already excludes `.env*`, so `.env` (without `.example`)
#   stays local to your machine.
# - These values are baked into the compiled firmware binary at build time
#   (via env!() in src/wifi.rs and src/api.rs). Anyone who dumps the flash
#   of a deployed device can extract the WiFi password in plaintext.
#   -> Use a dedicated/guest WiFi network for deployed sensors, not your
#      main home/personal network password.
#   -> For production deployments, prefer the AP-mode provisioning flow
#      planned in PLAN.md instead of compile-time credentials.

# WiFi network the gateway connects to (required, build-time)
WIFI_SSID=

# WiFi password (required, build-time)
# Use a guest/dedicated network password — see note above.
WIFI_PASS=

# Optional: override the sensor.community endpoint for local testing.
# Leave unset in production so the firmware uses the real HTTPS endpoint
# (https://api.sensor.community/v1/push-sensor-data/) with certificate
# validation enabled.
#API_URL=http://192.168.1.50:8080
